---
import { type BlogSchema } from "../content.config";
import BaseLayout from "./BaseLayout.astro";
import dayjs from "dayjs";
import localizedFormat from "dayjs/plugin/localizedFormat";
import slugify from "../lib/slugify";
import { withBase } from "../lib/withBase";
import { resolveBlogImage } from "../lib/blogImages";

export interface Props extends BlogSchema {}

const {
  title,
  description,
  pubDate,
  updatedDate,
  heroImage,
  heroCaption,
  badge,
  tags = [],
  categories = [],
} = Astro.props;
dayjs.extend(localizedFormat);
const displayDate = dayjs(pubDate).format("ll");
import { Image, getImage } from "astro:assets";

// heroImage is a path string; resolve to optimisable ImageMetadata (see lib/blogImages).
const hero = await resolveBlogImage(heroImage);
// og:image — derive ONE optimised social card from the hero (avoids emitting the original).
const ogImage = hero ? await getImage({ src: hero, width: 1200, format: "webp" }) : undefined;
---

<BaseLayout title={title} description={description} image={ogImage?.src} ogType="article">
  <main class="md:flex md:justify-center">
    <article class="prose prose-lg max-w-[750px] prose-img:mx-auto">
      <header class="text-center">
        {
          categories.length > 0 && (
            <div class="not-prose mb-3 flex flex-wrap justify-center gap-x-4">
              {categories.map((cat) => (
                <a
                  href={withBase(`/blog/category/${slugify(cat)}/`)}
                  class="text-primary text-sm font-bold uppercase tracking-wider underline underline-offset-4"
                >
                  {cat}
                </a>
              ))}
            </div>
          )
        }
        <h1 class="title mb-1 text-5xl font-bold leading-tight md:text-6xl">{title}</h1>
        {badge && <div class="badge badge-secondary mt-3">{badge}</div>}
        {
          pubDate && (
            <div class="not-prose mt-4 flex items-center justify-center gap-2 text-sm opacity-60">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                class="h-4 w-4"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
                />
              </svg>
              <time>{displayDate}</time>
              {updatedDate && <span>· updated {updatedDate}</span>}
            </div>
          )
        }
      </header>
      {
        hero && (
          <figure class="my-8">
            <Image
              src={hero}
              widths={[400, 750, 1100]}
              sizes="(min-width: 768px) 750px, 100vw"
              format="webp"
              alt={title}
              class="w-full"
            />
            {heroCaption && (
              <figcaption class="not-prose mt-2 text-center text-sm opacity-60">{heroCaption}</figcaption>
            )}
          </figure>
        )
      }

      <slot />

      <div class="not-prose my-12 text-center" role="separator" aria-label="End of post">
        <span class="text-2xl tracking-[0.3em] opacity-40 leading-none">⁂</span>
      </div>

      {
        tags.length > 0 && (
          <div class="not-prose flex flex-wrap items-center justify-center gap-2">
            {tags.map((tag) => (
              <a href={withBase(`/blog/tag/${slugify(tag)}/`)} class="badge badge-outline no-underline gap-1">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-3 w-3 shrink-0">
                  <path
                    fill-rule="evenodd"
                    d="M5.5 3A2.5 2.5 0 003 5.5v2.879a2.5 2.5 0 00.732 1.767l6.5 6.5a2.5 2.5 0 003.536 0l2.878-2.878a2.5 2.5 0 000-3.536l-6.5-6.5A2.5 2.5 0 008.38 3H5.5zM6 7a1 1 0 100-2 1 1 0 000 2z"
                    clip-rule="evenodd"
                  />
                </svg>
                {tag}
              </a>
            ))}
          </div>
        )
      }
    </article>
  </main>
</BaseLayout>
