---
const { title, img, desc, url, badge, tags, target = "_blank", loading = "eager" } = Astro.props;
import { Image } from "astro:assets";
import slugify from "../lib/slugify";
import { withBase } from "../lib/withBase";
import { isAsset, resolveAsset } from "../lib/assets";

// Blog heroes / project thumbnails arrive as a src/assets path string → resolve to
// optimisable ImageMetadata. Anything else (rare public/ string) is kept as-is below.
const resolved = isAsset(img) ? await resolveAsset(img) : img;
---

<div class="rounded-lg bg-base-100 hover:shadow-xl transition ease-in-out hover:scale-[102%]">
  <a href={url} target={target}>
    <div class="hero-content flex-col md:flex-row">
      {
        resolved &&
          (typeof resolved === "string" ? (
            // public/ path (e.g. project thumbnails) — not processed by Astro, needs explicit dims
            <Image
              src={withBase(resolved)}
              width={750}
              height={422}
              format="webp"
              alt={title}
              loading={loading}
              class="w-full md:max-w-[13rem] aspect-video object-cover rounded-lg"
            />
          ) : (
            // ImageMetadata from src/assets (e.g. blog hero) — Astro emits optimised WebP + srcset
            <Image
              src={resolved}
              widths={[260, 520]}
              sizes="(min-width: 768px) 13rem, 100vw"
              format="webp"
              alt={title}
              loading={loading}
              class="w-full md:max-w-[13rem] aspect-video object-cover rounded-lg"
            />
          ))
      }
      <div class="grow w-full">
        <h1 class="text-xl font-bold">
          {title}
          {badge && <div class="badge badge-primary mx-2">{badge}</div>}
        </h1>
        <p class="py-1 text-1xl">{desc}</p>
        <div class="card-actions justify-end">
          {
            tags &&
              tags.map((tag) => (
                <a href={withBase(`/blog/tag/${slugify(tag)}/`)} class="badge badge-soft badge-sm rounded-md no-underline">
                  {tag}
                </a>
              ))
          }
        </div>
      </div>
    </div>
  </a>
</div>
