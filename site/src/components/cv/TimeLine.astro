---
const { title, subtitle, accent = false } = Astro.props;
---

<div class="flex">
  <div class="education__time">
    <span class="w-4 h-4 bg-primary block rounded-full mt-1"></span>
    <span class="education__line bg-primary block h-full w-[2px] translate-x-[7px]"></span>
  </div>
  <div class="experience__data bd-grid px-5">
    <h3 class:list={["font-semibold mb-1", accent && "text-primary"]}>{title}</h3>
    <span class="text-sm text-muted">{subtitle}</span>
    <p class="my-2">
      <slot />
    </p>
  </div>
</div>
