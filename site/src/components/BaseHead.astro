---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import "../styles/global.css";
import { withBase } from "../lib/withBase";

export interface Props {
  title: string;
  description: string;
  image?: string;
  ogType?: string;
}

const { title, description, image = withBase("/avatar.jpg"), ogType = "website" } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url);
const imageURL = new URL(image, Astro.site ?? Astro.url);

// Schema.org Person — carried over (and modernised) from the old site's microdata.
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Diogo Nunes",
  gender: "Male",
  jobTitle: "Software Tester",
  url: (Astro.site ?? Astro.url).toString(),
  image: imageURL.toString(),
  sameAs: [
    "https://linkedin.com/in/nunesdiogo/",
    "https://github.com/dialex",
    "https://www.instagram.com/dialexnunes/",
    "https://www.goodreads.com/user/show/5802747-diogo",
    "https://twitter.com/dialexnunes",
  ],
};
---

<!-- Theme: apply the saved choice (or OS preference) before paint to avoid a flash.
     Runs synchronously in <head>; re-applies after Astro view-transition swaps and
     handles clicks on any [data-theme-toggle] button. -->
<script is:inline>
  (function () {
    function effectiveTheme() {
      var saved = localStorage.getItem("theme");
      if (saved === "emerald" || saved === "dim") return saved;
      return window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches ? "dim" : "emerald";
    }
    function applyTheme(theme) {
      document.documentElement.setAttribute("data-theme", theme);
      document.documentElement.classList.toggle("is-dark", theme === "dim");
    }
    applyTheme(effectiveTheme());
    // <html> attributes reset on client-side navigation — restore the theme.
    document.addEventListener("astro:after-swap", function () {
      applyTheme(effectiveTheme());
    });
    document.addEventListener("click", function (e) {
      if (!e.target.closest || !e.target.closest("[data-theme-toggle]")) return;
      var next = document.documentElement.getAttribute("data-theme") === "dim" ? "emerald" : "dim";
      localStorage.setItem("theme", next);
      applyTheme(next);
    });
  })();
</script>

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<meta name="author" content="Diogo Nunes" />
<link rel="canonical" href={canonicalURL} />

<!-- Favicons -->
<link rel="icon" type="image/svg+xml" href={withBase("/favicon.svg")} />
<link rel="icon" type="image/png" sizes="96x96" href={withBase("/favicon-96x96.png")} />
<link rel="shortcut icon" href={withBase("/favicon.ico")} />
<link rel="apple-touch-icon" sizes="180x180" href={withBase("/apple-touch-icon.png")} />
<link rel="manifest" href={withBase("/site.webmanifest")} />

<!-- Fonts: Lato (body) + Poppins (headings) -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  href="https://fonts.googleapis.com/css2?family=Lato:ital,wght@0,400;0,700;1,400;1,700&family=Poppins:wght@400;600;700&display=swap"
  rel="stylesheet"
/>

<!-- Mobile tab color -->
<meta name="theme-color" content="#66cc8a" />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={ogType} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageURL} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={imageURL} />
<meta name="twitter:site" content="@dialexnunes" />

<!-- Schema.org Person -->
<script type="application/ld+json" set:html={JSON.stringify(personSchema)} />

<!-- Google Analytics (GA4) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-XNL4QXTBGT"></script>
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag() {
    dataLayer.push(arguments);
  }
  gtag("js", new Date());
  gtag("config", "G-XNL4QXTBGT");
</script>
