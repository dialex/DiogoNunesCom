---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import createSlug from "../lib/createSlug";

// `date` is freeform ("2016", "2011-2025", "Since 2008", "Various"). Sort by the
// latest year mentioned, newest first; entries with no year (e.g. "Various") last.
const latestYear = (date: string) => {
  const years = date.match(/\d{4}/g);
  return years ? Math.max(...years.map(Number)) : 0;
};
const projects = (await getCollection("projects")).sort(
  (a, b) => latestYear(b.data.date) - latestYear(a.data.date),
);
---

<BaseLayout title="Projects" sideBarActiveItemID="projects">
  <div>
    <div class="text-3xl w-full font-bold font-heading mb-5">Projects</div>
  </div>

  {
    projects.map((project, index) => (
      <>
        <ProjectCard
          title={project.data.title}
          img={project.data.image}
          desc={project.data.description}
          date={project.data.date}
          skills={project.data.skills}
          url={`/projects/${createSlug(project.data.title, project.id)}`}
        />
        {index < projects.length - 1 && <div class="divider my-0" />}
      </>
    ))
  }
</BaseLayout>
