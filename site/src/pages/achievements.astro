    "desc": "Top 10 photo at <a href=\"https://www.dnacascais.pt/Default.aspx?ID=1725&M=News&PID=8441&NewsID=1303\">contest held by Cascais' city council</a>"
  },
  {
    "img": "premiosexcelencia.jpg",
    "date": "Aug 2008",
    "desc": "\"Excellent Student\" award at high school"
  }
];
---

<BaseLayout
  title="Achievements"
  sideBarActiveItemID="achievements"
>
  <div class="mb-8 text-center">
    <h1 class="text-5xl font-bold">Achievements 🏆</h1>
    <p class="py-3 text-lg">These are my personal achievements.</p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
    {
      achievements.map((a) => (
        <figure class="flex flex-col items-center text-center">
          <img
            src={`/achievements/${a.img}`}
            alt={a.date}
            loading="lazy"
            class="rounded-lg shadow-md w-full object-cover"
          />
          <figcaption class="mt-3">
            <span class="badge badge-info mr-1">{a.date}</span>
            <span set:html={a.desc} />
          </figcaption>
        </figure>
      ))
    }
  </div>
</BaseLayout>
