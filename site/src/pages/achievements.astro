    desc: 'Top 10 photo at <a href="https://www.dnacascais.pt/Default.aspx?ID=1725&M=News&PID=8441&NewsID=1303">contest held by Cascais\' city council</a>',
  },
  {
    img: "premiosexcelencia.jpg",
    date: "Aug '08",
    desc: '"Excellent Student" award at high school',
  },
];
---

<BaseLayout title="Achievements" sideBarActiveItemID="achievements" maxWidthClass="lg:max-w-[1080px]">
  <div class="mb-8 text-center">
    <h1 class="text-5xl font-bold">Achievements 🏆</h1>
    <p class="py-3 text-lg italic">My modest wall of fame</p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-[2.4rem]">
    {
      achievements.map((a) => (
        <figure class="achievement-card flex flex-col items-center text-center">
          <Image
            src={imageMap[a.img]}
            alt={a.date}
            widths={[520, 1040]}
            sizes="(min-width: 640px) 520px, 100vw"
            loading="lazy"
            decoding="async"
            class="bg-white p-1.5 border border-black/20 shadow-md max-w-full h-auto"
          />
          <figcaption class="mt-3 flex items-center justify-center gap-2 [&_a]:underline [&_a]:text-primary [&_a]:font-medium">
            <span class="badge badge-secondary shrink-0">{a.date}</span>
            <span set:html={a.desc} />
          </figcaption>
        </figure>
      ))
    }
  </div>
</BaseLayout>

<style>
  /* Skip rendering offscreen cards until near the viewport. `auto` lets the
     browser remember each card's real size after first paint, so the scrollbar
     stays stable. Pairs with the imgs' loading="lazy" (deferred fetch). */
  .achievement-card {
    content-visibility: auto;
    contain-intrinsic-size: auto 400px;
  }
</style>
