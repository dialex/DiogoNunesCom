import BaseLayout from "../layouts/BaseLayout.astro";
import { Image } from "astro:assets";
import { withBase } from "../lib/withBase";

// All achievement images live in src/assets so Astro optimises them (WebP + dimensions)
// at build. Glob-import them eagerly and key the map by filename to match the `img` field.
const imageModules = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/achievements/*.{jpg,JPG,jpeg,png,PNG}",
  { eager: true },
);
const imageMap: Record<string, ImageMetadata> = Object.fromEntries(
  Object.entries(imageModules).map(([path, mod]) => [path.split("/").pop()!, mod.default]),
);

// Personal achievements, newest first. Each entry: image + date + description.
