---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HorizontalCard from "../../components/HorizontalCard.astro";
import { getCollection } from "astro:content";
import createSlug from "../../lib/createSlug";

export async function getStaticPaths({ paginate }) {
  const posts = await getCollection("blog");
  posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
  return paginate(posts, { pageSize: 10 });
}

const { page } = Astro.props;

// Full post list (all pages) for client-side search — the visible list is
// paginated, so search must work off the complete set. Rendered with the same
// HorizontalCard as the default list so styling is identical; search only
// toggles visibility.
const allPosts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const searchText = (post) =>
  [post.data.title, post.data.description, ...(post.data.tags || []), ...(post.data.categories || [])]
    .join(" ")
    .toLowerCase();
---

<BaseLayout title="Blog" sideBarActiveItemID="blog">
  <div class="mb-5">
    <div class="text-3xl w-full font-bold font-heading">Blog</div>
  </div>

  <input
    id="blog-search"
    type="search"
    placeholder="Search posts…"
    autocomplete="off"
    class="input input-bordered w-full mb-5 focus:outline-none"
  />

  <div id="blog-search-results" hidden>
    <ul>
      {
        allPosts.map((post) => (
          <li class="search-item" data-text={searchText(post)}>
            <HorizontalCard
              title={post.data.title}
              img={post.data.heroImage}
              desc={post.data.description}
              url={"/blog/" + createSlug(post.data.title, post.id)}
              target="_self"
              badge={post.data.badge}
              tags={post.data.tags}
              loading="lazy"
            />
            <div class="divider my-0" />
          </li>
        ))
      }
    </ul>
    <div id="blog-search-empty" hidden class="bg-base-200 border-l-4 border-primary w-full p-4">
      <p class="font-bold">No posts found</p>
      <p>Nothing matches your search.</p>
    </div>
  </div>

  <div id="blog-default">
  {
    page.data.length === 0 ? (
      <div class="bg-base-200 border-l-4 border-primary w-full p-4 min-w-full">
        <p class="font-bold">Sorry!</p>
        <p>There are no blog posts to show at the moment. Check back later!</p>
      </div>
    ) : (
      <ul>
        {page.data.map((post) => (
          <>
            <HorizontalCard
              title={post.data.title}
              img={post.data.heroImage}
              desc={post.data.description}
              url={"/blog/" + createSlug(post.data.title, post.id)}
              target="_self"
              badge={post.data.badge}
              tags={post.data.tags}
            />
            <div class="divider my-0" />
          </>
        ))}
      </ul>
    )
  }

  <div class="flex justify-between">
    {
      page.url.prev ? (
        <a href={page.url.prev} class="btn btn-ghost my-10 mx-5">
          {" "}
          <svg
            class="h-6 w-6 fill-current md:h-8 md:w-8"
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
          >
            <path d="M15.41,16.58L10.83,12L15.41,7.41L14,6L8,12L14,18L15.41,16.58Z" />
          </svg>{" "}
          Recent posts
        </a>
      ) : (
        <div />
      )
    }
    {
      page.url.next ? (
        <a href={page.url.next} class="btn btn-ghost my-10 mx-5">
          Older Posts{" "}
          <svg
            class="h-6 w-6 fill-current md:h-8 md:w-8"
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
          >
            {" "}
            <path d="M8.59,16.58L13.17,12L8.59,7.41L10,6L16,12L10,18L8.59,16.58Z" />
          </svg>
        </a>
      ) : (
        <div />
      )
    }
  </div>
  </div>

  <script>
    // Runs on initial load AND after every client-side (View Transitions)
    // navigation — a plain inline script would only fire on a full page load.
    function initBlogSearch() {
      const input = document.getElementById("blog-search");
      if (!input) return; // not on the blog index
      const results = document.getElementById("blog-search-results");
      const defaultList = document.getElementById("blog-default");
      const empty = document.getElementById("blog-search-empty");
      const items = Array.from(results.querySelectorAll(".search-item"));

      function render(query) {
        const q = query.trim().toLowerCase();
        if (!q) {
          results.hidden = true;
          defaultList.hidden = false;
          return;
        }
        defaultList.hidden = true;
        results.hidden = false;
        let visible = 0;
        for (const item of items) {
          const match = item.dataset.text.includes(q);
          item.hidden = !match;
          if (match) visible++;
        }
        empty.hidden = visible > 0;
      }

      input.addEventListener("input", (e) => render(e.target.value));

      // Support /blog/?s=query (preserves the old WordPress search URLs):
      // prefill the box and filter.
      const q = new URLSearchParams(location.search).get("s");
      if (q) {
        input.value = q;
        render(q);
      }
    }

    document.addEventListener("astro:page-load", initBlogSearch);
  </script>
</BaseLayout>
