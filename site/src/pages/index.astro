---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { getCollection } from "astro:content";
import createSlug from "../lib/createSlug";

// Hand-picked entries to feature on the homepage, in display order. Each id is
// the filename in src/content/{projects,blog}/ without `.md`. A missing id is
// silently skipped (filter), so a typo won't break the build.
const pickByIds = (collection, ids) =>
  ids.map((id) => collection.find((e) => e.id === id)).filter((e) => e !== undefined);

const featuredProjectIds = ["pod-ser", "photography", "jcolor"];
const last_projects = pickByIds(await getCollection("projects"), featuredProjectIds);

const featuredPostIds = ["post1", "post2", "post3"];
const last_posts = pickByIds(await getCollection("blog"), featuredPostIds);
---

<BaseLayout sideBarActiveItemID="home">
  <div class="pb-12 mt-5">
    <div class="text-5xl font-bold font-heading">I'm Diogo 🦎</div>
    <div class="text-3xl py-3 font-heading">... the Geeky Gecko</div>
    <div class="py-2">
      <p class="text-lg">
        I'm a Quality Advocate (QA) from Portugal. My passion is using technology to improve people's lives. In my spare
        time I'm an amateur
        <a href="/pod">podcaster</a>,
        <a href="/photos">photographer</a>,
        <a href="/blog/">blogger</a>,
        <a href="/books">writer</a> and <a href="/udemy">teacher</a>.
      </p>
    </div>
    <div class="mt-8">
      <a class="btn" href="https://linkedin.com/in/nunesdiogo/" target="_blank">Let's connect!</a>
      <a href="/about" class="btn btn-outline ml-5">About me</a>
      <a href="/blog/" class="btn btn-outline ml-5">Read the blog</a>
    </div>
  </div>

  <div>
    <div class="text-3xl w-full font-bold font-heading mb-2">Favorite projects</div>
  </div>

  {
    last_projects.map((project, index) => (
      <>
        <HorizontalCard
          title={project.data.title}
          img={project.data.image}
          desc={project.data.description}
          url={"/projects/" + createSlug(project.data.title, project.id)}
          target="_self"
        />
        {index < last_projects.length - 1 && <div class="divider my-0" />}
      </>
    ))
  }

  <div class="mt-5 flex justify-center">
    <a href="/projects/" class="btn btn-outline">View more</a>
  </div>

  <div>
    <div class="text-3xl w-full font-bold font-heading mb-5 mt-10">Favorite posts</div>
  </div>

  {
    last_posts.map((post, index) => (
      <>
        <HorizontalCard
          title={post.data.title}
          img={post.data.heroImage}
          desc={post.data.description}
          url={"/blog/" + createSlug(post.data.title, post.id)}
          target="_self"
          badge={post.data.badge}
        />
        {index < last_posts.length - 1 && <div class="divider my-0" />}
      </>
    ))
  }

  <div class="mt-5 flex justify-center">
    <a href="/blog/" class="btn btn-outline">View more</a>
  </div>
</BaseLayout>
