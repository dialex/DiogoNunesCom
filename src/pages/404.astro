---
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../lib/withBase";
---

<BaseLayout title="404: Not Found" sideBarActiveItemID="">
  <div class="text-center">
    <div class="text-9xl font-bold mb-4" aria-hidden="true">🏝</div>
    <h1 class="text-9xl font-bold mb-2">404</h1>
    <p class="text-2xl">The page you're looking for couldn't be found.</p>
    <a class="btn btn-primary mt-9" href={withBase("/")}>Home</a>
  </div>
</BaseLayout>
