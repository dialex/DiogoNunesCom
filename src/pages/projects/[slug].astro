---
import { CollectionEntry, getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import createSlug from "../../lib/createSlug";
import { withBase } from "../../lib/withBase";
import { Image } from "astro:assets";
import { resolveAsset } from "../../lib/assets";

export async function getStaticPaths() {
  const projects = await getCollection("projects");
  return projects.map((entry) => ({
    params: { slug: createSlug(entry.data.title, entry.id) },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<"projects">;
}

const { entry } = Astro.props;
const project = entry.data;
const { Content } = await render(entry);
const detailImage = await resolveAsset(project.detailImage ?? project.image);
---

<BaseLayout title={project.title} sideBarActiveItemID="projects">
  <div class="flex flex-col items-center text-center gap-6">
    <a href={withBase("/projects/")} class="self-start text-sm text-muted hover:opacity-100">&larr; Back to projects</a>

    <header class="flex flex-col items-center gap-3">
      <h1 class="text-6xl font-bold">{project.title}</h1>
      <p class="text-sm text-muted">{project.date}</p>
      <div class="flex flex-wrap justify-center gap-2">
        {project.skills.map((skill) => <div class="badge badge-soft badge-sm rounded-md">{skill}</div>)}
      </div>
    </header>

    {
      project.detailVideo ? (
        <video
          src={withBase(project.detailVideo)}
          autoplay
          loop
          muted
          playsinline
          controls
          class="rounded-lg w-full max-w-2xl mx-auto"
        />
      ) : (
        detailImage && (
          <Image
            src={detailImage}
            widths={[400, 800, 1200]}
            sizes="(min-width: 768px) 42rem, 100vw"
            format="webp"
            alt={project.title}
            class="rounded-lg w-full max-w-2xl mx-auto"
          />
        )
      )
    }

    <div class="prose max-w-prose mx-auto">
      <Content />
    </div>

    {
      project.links && project.links.length > 0 && (
        <div class="flex flex-wrap justify-center gap-2 mt-2">
          {project.links.map((link) => (
            <a
              href={link.url.startsWith("/") ? withBase(link.url) : link.url}
              target="_blank"
              rel="noopener"
              class="btn btn-sm btn-outline"
            >
              {link.label}
            </a>
          ))}
        </div>
      )
    }
  </div>
</BaseLayout>
