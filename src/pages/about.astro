---
import BaseLayout from "../layouts/BaseLayout.astro";
import TimeLineElement from "../components/cv/TimeLine.astro";
import { withBase } from "../lib/withBase";
import { Image } from "astro:assets";
import avatar from "../assets/avatar.jpg";

// Content ported from the old /hireme résumé page. Brand logos live in
// public/brands; the avatar is the site-wide src/assets/avatar.jpg.

const traits = [
  {
    emoji: "🔦",
    title: "Guiding light",
    text: "One of my duties is to uncover information and deliver it, in a timely and convenient fashion. This allows the team to make decisions with more confidence and less assumptions.",
  },
  {
    emoji: "🔎",
    title: "Quality advocate",
    text: "My experience serves the team by advising development methodologies, practices and tools that favor quality. We will attain quality if we share that mindset and agree on a strategy.",
  },
  {
    emoji: "🐞",
    title: "Bug catcher",
    text: "Ideally we forecast issues and prevent them (shift left), but often humans make mistakes and systems fail, that's why we monitor and explore regularly (shift right). Bugs are reproduced, reported and prioritized according to risk.",
  },
  {
    emoji: "🤝",
    title: "Teammate",
    text: 'The team needs to build the right thing (Product) the right way (Engineering). Together, we are the "3 amigos" and we align/challenge expectations before coding. My role adapts to the team\'s needs, with flow and improvement always in mind.',
  },
  {
    emoji: "❤️",
    title: "(User) Friend",
    text: "We must listen to our users, their pains and their praises, because our services exist to serve them. I seek to make them happy, and also my colleagues! Because a happy team is a productive and resilient team!",
  },
  {
    emoji: "📗",
    title: "Eternal student",
    text: "Technology is constantly evolving, so it's crucial to maintain a curious and open mind. There's always new tools and techniques to discover... and advices from our colleagues too!",
  },
];

const technologies = [
  { name: "C#", percent: 75 },
  { name: "Git", percent: 75 },
  { name: "Java", percent: 70 },
  { name: "SQL", percent: 50 },
  { name: "JavaScript", percent: 40 },
  { name: "Docker", percent: 20 },
  { name: "Python", percent: 35 },
  { name: "Markdown", percent: 90 },
  { name: "Jenkins/GitLab/Travis", percent: 60 },
  { name: "Cheering up the team with memes", percent: 100 },
];

const testimonials = [
  {
    name: "Faiz M.",
    flag: "🇺🇸",
    url: "https://www.linkedin.com/in/faiz-merchant-0055b6133/",
    text: "Your fine attention to detail make you great at your job. But what really shines is that smile you always have. Just a really great personality and attitude overall.",
  },
  {
    name: "Giovanna F.",
    flag: "🇮🇹",
    url: "https://www.linkedin.com/in/fasogiovanna/",
    text: "He's dilligent, incredibly talented and meticulous and has been crucial in making sure we worked as a team.",
  },
  {
    name: "Neha D.",
    flag: "🇦🇺",
    url: "https://www.linkedin.com/in/nehadatt/",
    text: "I really respect your humility, dignity, openness and purity of heart and intention. A true leader.",
  },
  {
    name: "Kathleen C.",
    flag: "🇬🇧",
    url: "https://www.linkedin.com/in/collier-kathleen-8b17004/",
    text: "Intuitive, smart, empathetic, open minded, kind, funny, hard working, low ego, sharp. Everyone needs a Diogo in their lives.",
  },
  {
    name: "Jędrzej J.",
    flag: "🇵🇱",
    url: "https://www.linkedin.com/in/jedrzejjozefowicz/",
    text: "You always add these small improvements that make life easier or nicer. I wish everyone had just 10% of your attention.",
  },
  {
    name: "Mikhail K.",
    flag: "🇺🇦",
    url: "https://www.linkedin.com/",
    text: "You are a billiant QA, very thorough, creative and positive.",
  },
];

const clients = [
  { name: "MoonPay", img: "/brands/mp.png", url: "https://www.moonpay.com/" },
  { name: "Springer Nature", img: "/brands/sn.png", url: "https://www.springernature.com/gp" },
  { name: "Condé Nast", img: "/brands/condenast.png", url: "https://www.condenast.com/" },
  { name: "OLX Group", img: "/brands/olx.png", url: "https://www.olxgroup.com/" },
  { name: "Meetup", img: "/brands/meetup.png", url: "https://www.meetup.com/" },
  { name: "Plusgrade", img: "/brands/plusgrade.png", url: "https://www.plusgrade.com/" },
  {
    name: "Siemens Healthineers",
    img: "/brands/siemens-healthineers.png",
    url: "https://www.siemens-healthineers.com/",
  },
  { name: "Vocalink", img: "/brands/vocalink.png", url: "https://www.vocalink.com/" },
  { name: "Equal Experts", img: "/brands/equal-experts.png", url: "https://equalexperts.com/" },
  { name: "Deloitte", img: "/brands/deloitte.png", url: "https://www2.deloitte.com/pt/pt.html" },
];
---

<BaseLayout title="About me" sideBarActiveItemID="about">
  <!-- Header -->
  <div class="flex flex-col sm:flex-row items-center gap-6 mb-10">
    <Image src={avatar} width={120} height={120} format="webp" alt="Diogo Nunes" class="rounded-full" />
    <div>
      <h1 class="text-4xl font-bold">Diogo Nunes</h1>
      <div class="text-xl text-secondary font-heading">Quality Advocate</div>
      <div class="mt-3 flex flex-wrap gap-2">
        <a class="btn btn-sm btn-primary" href="https://linkedin.com/in/nunesdiogo/" target="_blank">LinkedIn</a>
        <a class="btn btn-sm btn-outline" href={withBase("/projects/")}>Portfolio</a>
        <a class="btn btn-sm btn-outline" href={withBase("/docs/cv.pdf")} target="_blank">Download CV</a>
      </div>
    </div>
  </div>

  <!-- Profile -->
  <div class="mb-5">
    <h2 class="text-3xl font-bold">Profile</h2>
  </div>
  <div class="mb-10">
    <p class="mb-3">
      My passion is using technology to improve people's lives. Professionally, I started as a developer, but now I'm a
      Quality Advocate (QA): I help teams ship reliable software that delights their users.
    </p>
    <p class="mb-3">
      I'm <b>organised and methodical</b>, with a keen eye for <b>usability</b> and another for <b>detail</b>. My
      empathy and positivity makes me a team asset. I <b>collaborate</b> with clients and developers to ensure the team delivers
      the right thing, built the right way. My past responsibilities range from those more <b>business</b> oriented (requirements,
      delivery, exploratory testing) to more <b>technical</b> ones (CI pipeline, automation in testing).
    </p>
    <p class="mb-3">
      Outside of work, I'm always building something. I'm an amateur
      <a href={withBase("/photos/")}>photographer</a> whose photos have been viewed millions of times on Unsplash, and a
      <a href={withBase("/books/")}>writer</a> of a couple of books. I was also a <a href={withBase("/blog/")}
        >blogger</a
      > for 9 years, a
      <a href={withBase("/pod/")}>podcaster</a> for 2 years, and even a <a href={withBase("/projects/lenda-lenga/")}
        >musician</a
      > once. Helping others fulfils me, so I volunteer a lot of my time: at conventions and local communities, writing
      <a href="https://github.com/dialex/">open source</a>,
      <a href="https://www.udemy.com/user/diogonunes4/">teaching</a> and <a href={withBase("/projects/pistae/")}
        >mentoring</a
      >.
    </p>
  </div>

  <!-- Traits -->
  <div class="mb-5">
    <h2 class="text-3xl font-bold">Traits</h2>
  </div>
  <div class="grid sm:grid-cols-2 gap-4 mb-10">
    {
      traits.map((trait) => (
        <div class="card bg-panel">
          <div class="card-body">
            <h3 class="card-title">
              <span class="text-2xl">{trait.emoji}</span>
              {trait.title}
            </h3>
            <p class="text-[15px]">{trait.text}</p>
          </div>
        </div>
      ))
    }
  </div>

  <!-- Testimonials -->
  <div class="mb-5">
    <h2 class="text-3xl font-bold">Testimonials</h2>
    <div class="text-sm italic text-muted">don't trust me, trust them!</div>
  </div>
  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-10">
    {
      testimonials.map((t) => (
        <div class="card bg-panel h-full">
          <div class="card-body">
            <h3 class="font-semibold">
              <a href={t.url} target="_blank">
                {t.name}
              </a>{" "}
              {t.flag}
            </h3>
            <p class="text-[15px]">{t.text}</p>
          </div>
        </div>
      ))
    }
  </div>

  <!-- Experience -->
  <div class="mb-5">
    <h2 class="text-3xl font-bold">Experience</h2>
  </div>
  <div class="time-line-container mb-10">
    <TimeLineElement title="Senior QA Engineer at MoonPay" subtitle="2022 – Present" accent>
      Own the Consumer roadmap and level up delivery processes, so teams move faster and deliver on time. Own delivery
      of cross-team initiatives. Triage 1000s of tickets (then use AI). Boost our quality.
    </TimeLineElement>
    <TimeLineElement title="Senior Quality Advocate at Springer Nature" subtitle="2020 – 2021" accent>
      Push for user and developer happiness (e.g. measure customer support, write E2E tests, pair with devs to improve
      UX, automate processes, mentor younger testers, lead knowledge sharing).
    </TimeLineElement>
    <TimeLineElement title="Quality Advocate (QA) at Equal Experts" subtitle="2016 – 2020" accent>
      Help my teammates be productive at delivering their best work (e.g. exploratory testing, automation in testing,
      continuous integration, 3-amigos, pairing, specification by example).
    </TimeLineElement>
    <TimeLineElement title="Software Developer at Loyty" subtitle="2014 – 2016" accent>
      Discuss requirements with client. Design mockups. Develop desktop app. Code back-end logic and integrations.
      Interact with databases (tables, SPs, views). Advise UI/UX.
    </TimeLineElement>
    <TimeLineElement title="IT Analyst at Deloitte" subtitle="2013" accent>
      Debug existing software applications. Write technical documentation.
    </TimeLineElement>
  </div>

  <!-- Education -->
  <div class="mb-5">
    <h2 class="text-3xl font-bold">Education</h2>
  </div>
  <div class="time-line-container mb-10">
    <TimeLineElement title="Master's degree at Técnico Lisboa" subtitle="2011 – 2013 · Computer Science · Grade: 17" accent>
      <strong>Major</strong>: Enterprise Information Systems – addresses the impact of information systems in
      organizations and how to model the systems and processes of such organizations. <strong>Minor</strong>: Software
      Engineering – addresses how to architect, manage and implement IT projects.
    </TimeLineElement>
    <TimeLineElement title="Bachelor's degree at Técnico Lisboa" subtitle="2008 – 2012 · Computer Science · Grade: 14" accent>
      University societies: Mentors (<a href="https://nape.tecnico.ulisboa.pt/en/mentorado/">NAPE</a>), Extracurricular
      activities (<a href="https://lage2.ist.utl.pt/">LAGE2</a>), <a href="https://tedxist.ist.utl.pt/#/">TEDxIST</a>,
      Photography group (<a href="https://www.facebook.com/gfist/">GFIST</a>).
    </TimeLineElement>
  </div>

  {
    /* Technologies — temporarily hidden
  <div class="mb-5">
    <h2 class="text-3xl font-bold">Technologies</h2>
    <div class="text-sm italic text-muted">how comfortable I am</div>
  </div>
  <div class="grid sm:grid-cols-2 gap-x-8 gap-y-4 mb-10">
    {technologies.map((tech) => (
      <div>
        <div class="font-semibold mb-1">{tech.name}</div>
        <progress class="progress progress-primary w-full" value={tech.percent} max="100" />
      </div>
    ))}
  </div>
  */
  }

  <!-- Clients -->
  <div class="mb-5">
    <h2 class="text-3xl font-bold">Clients</h2>
  </div>
  <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-6 items-center mb-10">
    {
      clients.map((c) => (
        <a href={c.url} target="_blank" title={c.name} class="flex justify-center">
          <img
            src={withBase(c.img)}
            alt={c.name}
            class="max-h-12 w-auto opacity-70 hover:opacity-100 transition grayscale hover:grayscale-0"
          />
        </a>
      ))
    }
  </div>
</BaseLayout>
