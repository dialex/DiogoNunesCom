---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { getCollection } from "astro:content";
import createSlug from "../lib/createSlug";
import { withBase } from "../lib/withBase";

// Hand-picked entries to feature on the homepage, in display order. Each id is
// the filename in src/content/{projects,blog}/ without `.md`. A missing id is
// silently skipped (filter), so a typo won't break the build.
const pickByIds = (collection, ids) =>
  ids.map((id) => collection.find((e) => e.id === id)).filter((e) => e !== undefined);

const featuredProjectIds = ["pod-ser", "photography", "jcolor"];
const last_projects = pickByIds(await getCollection("projects"), featuredProjectIds);

const featuredPostIds = [
  "a-friend-instead-of-a-pet",
  "happiness-oriented-testing-hot",
  "minecraft-a-game-as-a-metaphor-of-life",
  "orchestras-play-video-games-too",
  "average-at-everything-good-at-nothing",
];
const last_posts = pickByIds(await getCollection("blog"), featuredPostIds);
---

<BaseLayout sideBarActiveItemID="home">
  <div class="pb-12 mt-5">
    <h1 class="text-5xl font-bold">I'm Diogo 🦎</h1>
    <div class="text-3xl py-3 font-heading">... the Geeky Gecko</div>
    <div class="py-2">
      <p class="text-lg">
        I'm a Quality Advocate (QA) from Portugal. My passion is using technology to improve people's lives. In my spare
        time I'm an amateur
        <a href={withBase("/pod/")}>podcaster</a>,
        <a href={withBase("/photos/")}>photographer</a>,
        <a href={withBase("/blog/")}>blogger</a>,
        <a href={withBase("/books/")}>writer</a> and <a href={withBase("/udemy/")}>teacher</a>.
      </p>
    </div>
    <div class="mt-8">
      <a class="btn btn-primary" href={withBase("/about/")}>About me</a>
      <a class="btn ml-5" href={withBase("/projects/")}>My portfolio</a>
      <a class="btn ml-5" href={withBase("/blog/")}>My blog</a>
      <a class="btn ml-5" href={withBase("/books/")}>My books</a>
    </div>
  </div>

  <div>
    <h2 class="text-3xl font-bold mb-2">Favorite projects</h2>
  </div>

  {
    last_projects.map((project, index) => (
      <>
        <HorizontalCard
          title={project.data.title}
          img={project.data.image}
          desc={project.data.description}
          url={withBase("/projects/" + createSlug(project.data.title, project.id) + "/")}
          target="_self"
        />
        {index < last_projects.length - 1 && <div class="divider my-0" />}
      </>
    ))
  }

  <div class="mt-5 flex justify-center">
    <a href={withBase("/projects/")} class="btn btn-outline">View more projects</a>
  </div>

  <div>
    <h2 class="text-3xl font-bold mb-5 mt-10">Favorite posts</h2>
  </div>

  {
    last_posts.map((post, index) => (
      <>
        <HorizontalCard
          title={post.data.title}
          img={post.data.heroImage}
          desc={post.data.description}
          url={withBase("/blog/" + createSlug(post.data.title, post.id) + "/")}
          target="_self"
          badge={post.data.badge}
        />
        {index < last_posts.length - 1 && <div class="divider my-0" />}
      </>
    ))
  }

  <div class="mt-5 flex justify-center">
    <a href={withBase("/blog/")} class="btn btn-outline">Read more posts</a>
  </div>
</BaseLayout>
