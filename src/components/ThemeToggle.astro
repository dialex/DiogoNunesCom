---
// Light/dark toggle. The actual logic (persist + apply + OS detection) lives in
// the inline script in BaseHead, which delegates clicks on [data-theme-toggle].
// Icon visibility is driven by the `.is-dark` class on <html> (see global.css).
---

<button
  type="button"
  data-theme-toggle
  class="btn btn-ghost btn-square"
  aria-label="Toggle light/dark mode"
  title="Toggle light/dark mode"
>
  <svg
    class="icon-sun w-5 h-5"
    xmlns="http://www.w3.org/2000/svg"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    stroke-width="2"
  >
    <circle cx="12" cy="12" r="4"></circle>
    <path
      stroke-linecap="round"
      d="M12 2v2M12 20v2M2 12h2M20 12h2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M19.1 4.9l-1.4 1.4M6.3 17.7l-1.4 1.4"
    >
    </path>
  </svg>
  <svg
    class="icon-moon w-5 h-5"
    xmlns="http://www.w3.org/2000/svg"
    fill="none"
    viewBox="0 0 24 24"
    stroke="currentColor"
    stroke-width="2"
  >
    <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
  </svg>
</button>
